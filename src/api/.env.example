# =============================================================================
# AI Code Generation SaaS Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the actual values.
# NEVER commit .env to git - it contains sensitive credentials.
# =============================================================================

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# Application display name
APP_NAME="AI Code Generation API"

# Application version (should match pyproject.toml)
APP_VERSION="0.1.0"

# Deployment environment: development, staging, or production
ENVIRONMENT="development"

# Enable debug mode (true for development, false for production)
DEBUG="true"

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# Secret key for signing tokens and sessions
# Generate with: openssl rand -hex 32
SECRET_KEY="your-secret-key-here-generate-with-openssl-rand-hex-32"

# JWT secret key for signing JWT tokens (should be different from SECRET_KEY)
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY="your-jwt-secret-key-here-generate-with-openssl-rand-hex-32"

# JWT algorithm (recommended: HS256)
JWT_ALGORITHM="HS256"

# JWT access token expiration in minutes (default: 30 minutes)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES="30"

# JWT refresh token expiration in days (default: 7 days)
JWT_REFRESH_TOKEN_EXPIRE_DAYS="7"

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# PostgreSQL connection URL with asyncpg driver
# Format: postgresql+asyncpg://username:password@host:port/database
# Example: postgresql+asyncpg://aicodegen:secure_password@localhost:5432/aicodegen
DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/aicodegen"

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
# Redis connection URL for caching and session storage
# Format: redis://host:port/db_number
# Example: redis://localhost:6379/0
REDIS_URL="redis://localhost:6379/0"

# -----------------------------------------------------------------------------
# Email Configuration
# -----------------------------------------------------------------------------
# SendGrid API key for sending transactional emails
# Get your API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=""

# Default sender email address
EMAIL_FROM="noreply@aicodegen.example.com"

# Email verification token expiration in hours (default: 24 hours)
VERIFICATION_TOKEN_EXPIRE_HOURS="24"

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
# Frontend application URL for CORS and email links
# Development: http://localhost:3000
# Production: https://your-domain.com
FRONTEND_URL="http://localhost:3000"
